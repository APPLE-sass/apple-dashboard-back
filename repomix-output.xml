// prisma/schema.prisma
generator client {
  provider   = "prisma-client-js"
  output     = "../node_modules/.prisma/client"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// AUTH
// ─────────────────────────────────────────

enum Role {
  ADMIN
  VENDEDOR
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  nombre       String
  passwordHash String   @map("password_hash")
  role         Role     @default(VENDEDOR)
  refreshToken String?  @map("refresh_token")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([email])
  @@map("users")
}

// ─────────────────────────────────────────
// ACCESORIOS DE MARCA (ej. funda para iPhone 17 Pro)
// ─────────────────────────────────────────

model Accesorio {
  id          String   @id @default(uuid())
  nombre      String                      // ej. "iPhone 17"
  modelo      String                      // ej. "Pro"
  tipo        String                      // ej. "Funda", "Templado"
  descripcion String?
  cantidad    Int      @default(0)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  colores  AccesorioColor[]
  imagenes AccesorioImagen[]

  puntoDeVentaId String       @map("punto_de_venta_id")
  puntoDeVenta   PuntoDeVenta @relation(fields: [puntoDeVentaId], references: [id])

  @@index([puntoDeVentaId])
  @@index([nombre])
  @@index([tipo])
  @@map("accesorios")
}

model AccesorioColor {
  id          String    @id @default(uuid())
  color       String

  accesorioId String    @map("accesorio_id")
  accesorio   Accesorio @relation(fields: [accesorioId], references: [id], onDelete: Cascade)

  @@index([accesorioId])
  @@map("accesorio_colores")
}

model AccesorioImagen {
  id          String    @id @default(uuid())
  url         String
  orden       Int       @default(0)
  createdAt   DateTime  @default(now()) @map("created_at")

  accesorioId String    @map("accesorio_id")
  accesorio   Accesorio @relation(fields: [accesorioId], references: [id], onDelete: Cascade)

  @@index([accesorioId])
  @@map("accesorio_imagenes")
}

// ─────────────────────────────────────────
// ACCESORIOS GENÉRICOS (sin marca, ej. cable USB-C genérico)
// ─────────────────────────────────────────

model SubAccesorio {
  id          String   @id @default(uuid())
  nombre      String                      // ej. "Cable USB-C"
  tipo        String                      // ej. "Cable", "Cargador"
  descripcion String?
  cantidad    Int      @default(0)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  colores  SubAccesorioColor[]
  imagenes SubAccesorioImagen[]

  puntoDeVentaId String       @map("punto_de_venta_id")
  puntoDeVenta   PuntoDeVenta @relation(fields: [puntoDeVentaId], references: [id])

  @@index([puntoDeVentaId])
  @@index([nombre])
  @@index([tipo])
  @@map("sub_accesorios")
}

model SubAccesorioColor {
  id             String       @id @default(uuid())
  color          String

  subAccesorioId String       @map("sub_accesorio_id")
  subAccesorio   SubAccesorio @relation(fields: [subAccesorioId], references: [id], onDelete: Cascade)

  @@index([subAccesorioId])
  @@map("sub_accesorio_colores")
}

model SubAccesorioImagen {
  id             String       @id @default(uuid())
  url            String
  orden          Int          @default(0)
  createdAt      DateTime     @default(now()) @map("created_at")

  subAccesorioId String       @map("sub_accesorio_id")
  subAccesorio   SubAccesorio @relation(fields: [subAccesorioId], references: [id], onDelete: Cascade)

  @@index([subAccesorioId])
  @@map("sub_accesorio_imagenes")
}

// ─────────────────────────────────────────
// PUNTOS DE VENTA
// ─────────────────────────────────────────


model PuntoDeVenta {
  id        String   @id @default(uuid())
  nombre    String
  direccion String?
  ciudad    String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  accesorios    Accesorio[]
  subAccesorios SubAccesorio[]

  @@map("puntos_de_venta")
}
